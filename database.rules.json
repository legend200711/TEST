{
  "rules": {
    "liveRooms": {
      "$roomId": {
        ".read":  "auth != null",
        ".write": "auth != null"
      }
    },
    "liveConnections": {
      "$roomId": {
        ".read":  "auth != null",
        ".write": "auth != null"
      }
    },
    "stormRooms": {
      "$roomId": {
        ".read":  "auth != null",
        ".write": "auth != null"
      }
    },
    "supportRooms": {
      "$roomId": {
        ".read":  "auth != null",
        ".write": "auth != null"
      }
    },
    "userLive": {
      "$uid": {
        ".read":  "auth != null",
        ".write": "auth != null && auth.uid == $uid"
      }
    }
  }
}
