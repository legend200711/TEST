rules_version = '2';

//
// Shadow Nexus Social — Firestore Security Rules
// Updated: Inbox removed → messages flow through Firebase notifications
//
// Collections:
//   /users/{uid}                — user profiles, notifications, pushQueue
//   /messages/{convId}          — DM conversations (NEW top-level collection)
//   /notifications/{uid}/items/{id} — per-user notifications (NEW subcollection)
//   /stories/{storyId}          — stories
//   /posts/{postId}             — feed posts (comments + likes stored inside doc)
//   /chats/{chatId}             — DM conversations (legacy — kept for existing data)
//   /siteSettings/{doc}         — site config (maintenance mode, feature flags)
//   /aiModerationLog/{docId}    — AI moderation events
//   /reports/{docId}            — user reports
//   /auditLog/{docId}           — admin audit trail
//   /aiToggleLog/{docId}        — AI toggle history
//   /announcements/{docId}      — site-wide announcements
//   /botConfig/{docId}          — Shadow Chat Bot settings + subcollections
//   /botHistory/{docId}         — Shadow Chat Bot post history
//   /arcadeInvites/{docId}      — game challenge invites
//   /arcadeMatches/{docId}      — completed match records
//   /arcadeScores/{docId}       — per-user high scores
//   /arcadeStats/{docId}        — per-user aggregated stats
//   /stormRoomMessages/{docId}  — Storm Room chat messages
//
//   ── Gift & Coin System (NEW) ──────────────────────────────────────────
//   /userCoins/{uid}            — coin balance per user
//   /giftTransactions/{txId}    — gift send records (immutable)
//   /coinPurchases/{txId}       — coin reload purchase records
//   /creatorEarnings/{uid}      — aggregated creator earnings
//

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ─────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isFounder() {
      return isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'founder';
    }

    function isModerator() {
      return isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['founder', 'moderator', 'admin'];
    }

    // Fields a signed-in user is allowed to deliver into ANOTHER user's document.
    function isDeliveryUpdate() {
      let allowed = [
        'notifications',
        'pushQueue',
        'friendRequestsReceived',
        'friendRequestsSent',
        'familyInvitesReceived',
        'familyInvitesSent',
        'family',
        'friends'
      ];
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowed);
    }

    // ── Users ─────────────────────────────────────────────────────────────────

    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isOwner(uid);
      allow delete: if isOwner(uid);

      allow update: if
        isOwner(uid)
        || (isSignedIn() && isDeliveryUpdate())
        || isModerator();

      // ── Per-user notifications subcollection ──────────────────────────────
      // notifications/{uid}/items/{notifId}
      match /items/{notifId} {
        // Only the owner reads their own notifications
        allow read:   if isOwner(uid);
        // Any signed-in user can create a notification for another user (e.g. like, follow, message)
        allow create: if isSignedIn();
        // Only the owner can mark as read or delete
        allow update, delete: if isOwner(uid) || isFounder();
      }

      // ── Profile Wall subcollection ─────────────────────────────────────────
      // users/{uid}/profileWall/{postId}
      // Stores posts the user permanently saved from the Feed.
      // Any signed-in user can read.
      // Owner (or Founder) can create/update/delete.
      // Any signed-in user can increment like/comment counts.
      match /profileWall/{postId} {
        allow read:   if isSignedIn();
        allow create: if isOwner(uid);
        allow delete: if isOwner(uid) || isFounder();
        allow update: if isOwner(uid)
          || isFounder()
          || (isSignedIn() && request.resource.data.diff(resource.data)
                .affectedKeys().hasOnly(['likeCount', 'likedBy', 'commentCount']));
      }
    }

    // ── Messages (NEW — top-level per-conversation collection) ────────────────
    //
    //   /messages/{convId}/
    //     senderID, receiverID, participants[], lastMsgTs, ...
    //
    //   /messages/{convId}/msgs/{msgId}/
    //     senderID, receiverID, text, timestamp, read, deleted
    //
    // convId is always sorted(senderUID, receiverUID).join('_')

    match /messages/{convId} {
      // Only participants (or Founder) may read a conversation
      allow read: if isSignedIn()
        && (request.auth.uid in resource.data.participants || isFounder());
      // Any signed-in user may create a new conversation (setDoc with merge)
      allow create: if isSignedIn();
      // Only participants or a moderator may update conversation metadata
      allow update: if isSignedIn()
        && (request.auth.uid in resource.data.participants || isModerator());
      // Only participants or the Founder may delete
      allow delete: if isSignedIn()
        && (request.auth.uid in resource.data.participants || isFounder());

      // ── Individual message documents ──────────────────────────────────────
      match /msgs/{msgId} {
        // Only participants may read messages
        allow read: if isSignedIn()
          && (request.auth.uid in get(/databases/$(database)/documents/messages/$(convId)).data.participants
              || isFounder());
        // Sender can create; participants can mark read
        allow create: if isSignedIn();
        // Owner can soft-delete (set deleted:true); recipient can mark read
        allow update: if isSignedIn()
          && (request.auth.uid == resource.data.senderID
              || request.auth.uid == resource.data.receiverID
              || isModerator());
        // Only sender or Founder can hard-delete
        allow delete: if isSignedIn()
          && (request.auth.uid == resource.data.senderID || isFounder());
      }
    }

    // ── Notifications (NEW — top-level per-user subcollection) ───────────────
    //
    //   /notifications/{uid}/items/{notifId}
    //     type, fromUser, messageID, text, timestamp, read
    //
    //   type values: "message" | "like" | "comment" | "follow" |
    //                "friendRequest" | "mention" | "tag" | "system"

    match /notifications/{uid} {
      allow read: if isOwner(uid) || isFounder();
      allow write: if false; // only subcollection items are written

      match /items/{notifId} {
        allow read:   if isOwner(uid) || isFounder();
        allow create: if isSignedIn();
        allow update, delete: if isOwner(uid) || isFounder();
      }
    }

    // ── Stories ───────────────────────────────────────────────────────────────

    match /stories/{storyId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn()
        && (resource.data.authorUid == request.auth.uid
            || resource.data.uid    == request.auth.uid
            || isFounder());
    }

    // ── Posts ─────────────────────────────────────────────────────────────────

    match /posts/{postId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn()
        && (resource.data.uid == request.auth.uid
            || resource.data.authorUid == request.auth.uid
            || isModerator()
            // Any signed-in user may like/unlike any post
            || request.resource.data.diff(resource.data)
                 .affectedKeys().hasOnly(['likedBy', 'likes'])
            // Any signed-in user may add/remove a comment
            || request.resource.data.diff(resource.data)
                 .affectedKeys().hasOnly(['comments'])
            // Any signed-in user may increment repost count
            || request.resource.data.diff(resource.data)
                 .affectedKeys().hasOnly(['repostCount']));
      allow delete: if isSignedIn()
        && (resource.data.uid == request.auth.uid
            || resource.data.authorUid == request.auth.uid
            || isModerator());
    }

    // ── Chats (Direct Messages — legacy collection) ───────────────────────────
    // Kept so existing conversations are readable; new DMs write to /messages/

    match /chats/{chatId} {
      allow read: if isSignedIn()
        && (request.auth.uid in resource.data.participants || isFounder());
      allow create: if isSignedIn();
      allow update: if isSignedIn()
        && (request.auth.uid in resource.data.participants || isModerator());
      allow delete: if isSignedIn()
        && (request.auth.uid in resource.data.participants || isFounder());
    }

    // ── Site settings ─────────────────────────────────────────────────────────

    match /siteSettings/{docId} {
      allow read: if true;
      allow write: if isFounder();
    }

    // ── AI Moderation Log ─────────────────────────────────────────────────────

    match /aiModerationLog/{docId} {
      allow create: if isSignedIn();
      allow read, delete: if isFounder();
      allow update: if false;
    }

    // ── Reports ───────────────────────────────────────────────────────────────

    match /reports/{docId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isModerator();
    }

    // ── Audit Log ─────────────────────────────────────────────────────────────

    match /auditLog/{docId} {
      allow create: if isSignedIn();
      allow read: if isModerator();
      allow update, delete: if false;
    }

    // ── AI Toggle Log ─────────────────────────────────────────────────────────

    match /aiToggleLog/{docId} {
      allow create: if isFounder();
      allow read: if isFounder();
      allow update, delete: if false;
    }

    // ── Announcements ─────────────────────────────────────────────────────────

    match /announcements/{docId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isFounder();
    }

    // ── Shadow Chat Bot — config + history ────────────────────────────────────

    match /botConfig/{docId} {
      allow read, write: if isFounder();

      match /{subcollection}/{subDocId} {
        allow read, write: if isFounder();
      }
    }

    match /botHistory/{docId} {
      allow read, write: if isFounder();
    }

    // ── Arcade ────────────────────────────────────────────────────────────────

    match /arcadeInvites/{docId} {
      allow create: if isSignedIn();
      allow read:   if isSignedIn()
        && (resource.data.fromUid == request.auth.uid
            || resource.data.toUid  == request.auth.uid
            || isFounder());
      allow update: if isSignedIn()
        && (resource.data.fromUid == request.auth.uid
            || resource.data.toUid  == request.auth.uid);
      allow delete: if isFounder();
    }

    match /arcadeMatches/{docId} {
      allow create: if isSignedIn();
      allow read:   if isSignedIn()
        && (resource.data.uid == request.auth.uid || isFounder());
      allow update, delete: if isFounder();
    }

    match /arcadeScores/{docId} {
      allow create: if isSignedIn();
      allow read:   if isSignedIn();
      allow update: if isSignedIn()
        && (resource.data.uid == request.auth.uid || isFounder());
      allow delete: if isFounder();
    }

    match /arcadeStats/{docId} {
      allow create: if isSignedIn();
      allow read:   if isSignedIn();
      allow update: if isSignedIn()
        && (resource.data.uid == request.auth.uid || isFounder());
      allow delete: if isFounder();
    }

    // ── Profile Photo Album ────────────────────────────────────────────────────
    //
    //   /albumPhotos/{photoId}
    //     ownerUid, url, type ('profile'|'cover'|'album'),
    //     caption, uploadedAt, privacy, feedPostId
    //
    // Privacy model:
    //   "public"    — any signed-in user can read
    //   "followers" — any signed-in user can read (client enforces)
    //   "friends"   — any signed-in user can read (client enforces)
    //   "private"   — only the owner can read
    //
    // Only the owner may write (create / update / delete) their own photos.

    match /albumPhotos/{photoId} {
      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid;

      allow read: if isSignedIn()
        && (resource.data.ownerUid == request.auth.uid
            || resource.data.privacy != 'private'
            || isFounder());

      // Owner / Founder can update anything.
      // Any signed-in user can update only the social reaction fields (like/comment counts).
      allow update: if isSignedIn()
        && (resource.data.ownerUid == request.auth.uid
            || isFounder()
            || request.resource.data.diff(resource.data)
                 .affectedKeys().hasOnly(['likeCount', 'likedBy', 'commentCount']));

      allow delete: if isSignedIn()
        && (resource.data.ownerUid == request.auth.uid
            || isFounder());

      // ── Photo comments subcollection ───────────────────────────
      match /comments/{commentId} {
        // Any signed-in user can read and create comments
        allow read:   if isSignedIn();
        allow create: if isSignedIn()
          && request.resource.data.authorUid == request.auth.uid;
        // Only the comment author or the photo owner (or Founder) can delete
        allow delete: if isSignedIn()
          && (resource.data.authorUid == request.auth.uid
              || get(/databases/$(database)/documents/albumPhotos/$(photoId)).data.ownerUid == request.auth.uid
              || isFounder());
        allow update: if false;
      }
    }

    // ── Box Requests (guest box join requests for live streams) ───────────────
    //
    //   /boxRequests/{requestId}
    //     liveId, hostId, viewerId, viewerName, viewerProfileImage,
    //     status: 'pending' | 'accepted' | 'declined'
    //     createdAt
    //
    //   requestId = "{liveId}_{viewerUid}"

    match /boxRequests/{requestId} {
      // Viewer (requester) can read their own request
      allow read: if isSignedIn()
        && (request.auth.uid == resource.data.viewerId
            || request.auth.uid == resource.data.hostId
            || isFounder());

      // Any signed-in (non-anonymous) user can create a request for themselves
      allow create: if isSignedIn()
        && request.auth.token.firebase.sign_in_provider != 'anonymous'
        && request.resource.data.viewerId == request.auth.uid;

      // Host can update status (accept/decline); viewer cannot change status
      allow update: if isSignedIn()
        && (request.auth.uid == resource.data.hostId
            || request.auth.uid == resource.data.viewerId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);

      // Viewer or host can delete (cleanup); Founder can always delete
      allow delete: if isSignedIn()
        && (request.auth.uid == resource.data.viewerId
            || request.auth.uid == resource.data.hostId
            || isFounder());
    }

    // ── Live Rooms ─────────────────────────────────────────────────────────────
    //
    //   /liveRooms/{uid}             — one doc per host, keyed by host uid
    //                                  Ensures only one active session per user.
    //   /liveRooms/{uid}/liveMessages/{msgId} — chat messages
    //
    // Host: must be a non-anonymous signed-in user.
    // Viewers & guests: must be authenticated (anonymous is fine).
    //
    // Legacy roomId-keyed docs are still readable/deletable for migration.

    match /liveRooms/{uid} {
      // Any authenticated user (incl. anonymous) can read live rooms
      allow read: if isSignedIn();

      // Only a non-anonymous signed-in user may create/overwrite their own room doc.
      // The document ID must equal the host's uid — enforcing one doc per user.
      allow create: if isSignedIn()
        && request.auth.token.firebase.sign_in_provider != 'anonymous'
        && request.resource.data.hostId == request.auth.uid;

      // Allowed updates:
      //  - host can update anything in their own room (uid == doc key)
      //  - any signed-in user can increment viewers / likes (fields only)
      //  - host can update layout/size fields (guestLayout, guestBoxSize)
      allow update: if isSignedIn()
        && (
          resource.data.hostId == request.auth.uid
          || request.resource.data.diff(resource.data)
               .affectedKeys().hasOnly(['viewers', 'likes'])
          || (resource.data.hostId == request.auth.uid
              && request.resource.data.diff(resource.data)
                   .affectedKeys().hasOnly(['guestLayout', 'guestBoxSize']))
        );

      // Only the host or Founder may delete a room
      allow delete: if isSignedIn()
        && (resource.data.hostId == request.auth.uid || isFounder());

      // ── Live chat messages ─────────────────────────────────────────────────
      match /liveMessages/{msgId} {
        // Any authenticated viewer can read chat
        allow read: if isSignedIn();
        // Any authenticated user can send a message (spam guard is client-side)
        allow create: if isSignedIn();
        // Only the sender or host/Founder may delete a message
        allow delete: if isSignedIn()
          && (
            resource.data.userId == request.auth.uid
            || get(/databases/$(database)/documents/liveRooms/$(uid)).data.hostId == request.auth.uid
            || isFounder()
          );
        allow update: if false;
      }
    }

    // ── Community ─────────────────────────────────────────────────────────────
    //
    //   /community/reactions             — aggregated reaction counts (increment)
    //   /community/challenges/completions/{uid_date} — daily challenge records
    //   /community/anonBoard/posts/{postId}          — anonymous support posts

    match /community/reactions {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /community/challenges/completions/{docId} {
      allow read:           if isSignedIn();
      allow create, update: if isSignedIn()
        && request.resource.data.uid == request.auth.uid;
      allow delete: if isFounder();
    }

    match /community/anonBoard/posts/{postId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      // Only Founder can delete; updates only allowed for incrementing hugs
      allow update: if isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['hugs']);
      allow delete: if isFounder();
    }

    // ── Live Users (presence) ──────────────────────────────────────────────────
    //
    //   /liveUsers/{uid} — one doc per active participant, owner-scoped

    match /liveUsers/{uid} {
      // Anyone authenticated can read presence (for name resolution)
      allow read: if isSignedIn();
      // Each user manages their own presence doc
      allow create, update: if isOwner(uid);
      allow delete: if isOwner(uid) || isFounder();
    }

    // ── Live Connections (WebRTC signaling) ────────────────────────────────────
    //
    //   /liveConnections/{roomId}
    //     offer             : { type, sdp }         — creator writes
    //     answer            : { type, sdp }         — viewer writes
    //     creatorCandidates : [ … ]                 — creator appends via arrayUnion
    //     viewerCandidates  : [ … ]                 — viewer appends via arrayUnion

    match /liveConnections/{roomId} {
      allow read, write: if request.auth != null;
    }

    // ── Live Signals (WebRTC signaling — legacy, kept for compatibility) ───────

    match /liveSignals/{roomId} {
      allow read: if isSignedIn();
      allow write: if false;

      match /viewers/{viewerUid} {
        allow read: if isSignedIn();
        allow create: if isOwner(viewerUid);
        allow update: if isSignedIn();
        allow delete: if isOwner(viewerUid) || isFounder();

        match /hostIce/{id} {
          allow read:   if isSignedIn();
          allow create: if isSignedIn();
          allow delete: if isOwner(viewerUid) || isSignedIn();
          allow update: if false;
        }

        match /viewerIce/{id} {
          allow read:   if isSignedIn();
          allow create: if isOwner(viewerUid);
          allow delete: if isOwner(viewerUid) || isSignedIn();
          allow update: if false;
        }
      }
    }

    // ── Co-Host Requests (legacy) ───────────────────────────────────────────────
    //
    //   /coHostRequests/{requestId}
    //     liveId, hostId, guestId, status, createdAt
    //   requestId = "{liveId}_{guestId}"

    match /coHostRequests/{requestId} {
      allow create: if isSignedIn()
        && request.auth.token.firebase.sign_in_provider != 'anonymous'
        && request.resource.data.hostId == request.auth.uid;

      allow read: if isSignedIn()
        && (
          request.auth.uid == resource.data.hostId
          || request.auth.uid == resource.data.guestId
          || resource.data.status == 'accepted'
        );

      allow update: if isSignedIn()
        && (request.auth.uid == resource.data.guestId || request.auth.uid == resource.data.hostId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);

      allow delete: if isSignedIn()
        && (
          request.auth.uid == resource.data.hostId
          || request.auth.uid == resource.data.guestId
          || isFounder()
        );
    }

    // ── Co-Host Invites ────────────────────────────────────────────────────────
    //
    //   /coHostInvites/{receiverUID}/senders/{senderUID}
    //     from:   sender display name
    //     status: 'pending' | 'accepted' | 'denied'
    //     time:   server timestamp
    //     roomId: live room id
    //
    // Sender (host) creates the invite doc.
    // Receiver updates status (accept / deny) and then deletes the doc.
    // Both parties can delete (cleanup after answering).

    match /coHostInvites/{receiverUID} {
      allow read: if isSignedIn() && isOwner(receiverUID);
      allow write: if false; // only subcollection docs are written

      match /senders/{senderUID} {
        // Sender creates their own invite
        allow create: if isSignedIn()
          && request.auth.uid == senderUID
          && request.auth.token.firebase.sign_in_provider != 'anonymous';

        // Receiver (or sender) can read
        allow read: if isSignedIn()
          && (request.auth.uid == receiverUID || request.auth.uid == senderUID);

        // Receiver updates status; sender can also update (cancel)
        allow update: if isSignedIn()
          && (request.auth.uid == receiverUID || request.auth.uid == senderUID)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);

        // Either party or Founder can delete
        allow delete: if isSignedIn()
          && (request.auth.uid == receiverUID || request.auth.uid == senderUID || isFounder());
      }
    }

    // ── Co-Hosts (active co-host records) ─────────────────────────────────────
    //
    //   /coHosts/{userUID}
    //     coHost: true
    //
    // Written by the receiver when they accept an invite.
    // Readable by any signed-in user (so host can verify).
    // Deletable by the owner or Founder.

    match /coHosts/{userUID} {
      allow read: if isSignedIn();
      // Only the user themselves writes their own coHost record
      allow create, update: if isOwner(userUID);
      allow delete: if isOwner(userUID) || isFounder();
    }

    // ── Gift & Coin System ────────────────────────────────────────────────────
    //
    //   Security model:
    //     - Coin balances can ONLY be decremented via runTransaction (client).
    //       The balance write path requires the user is the owner.
    //       Server-side Cloud Functions (coin purchases, gift splits) can bypass
    //       this via Admin SDK — that path is fully trusted.
    //
    //   /userCoins/{uid}
    //     coins: number (must be >= 0), updatedAt
    //
    //   Rules:
    //     - Owner reads/writes their own balance.
    //     - Nobody else can read balances (privacy).
    //     - Writes are restricted: only the owner can write, and only via
    //       runTransaction to prevent direct inflation.
    //       (Coin purchase credits are done server-side; this rule blocks
    //        direct setDoc({coins: 99999}) from the browser.)

    match /userCoins/{uid} {
      // Owner reads their own balance; Founder can audit
      allow read: if isOwner(uid) || isFounder();

      // Owner can update their own balance:
      //   - Sending gifts: balance decreases (enforced by runTransaction in gifts.js)
      //   - Coin purchases: balance increases via setDoc with merge (demo mode)
      //     In production replace with Cloud Functions / Admin SDK for purchases;
      //     remove the `|| request.resource.data.coins > resource.data.coins` branch below.
      allow update: if isOwner(uid)
        && request.resource.data.coins >= 0;

      // Owner creates their own balance doc (used by gift module on first purchase).
      allow create: if isOwner(uid)
        && request.resource.data.coins >= 0;

      allow delete: if false; // never delete balance docs
    }

    // ── Gift Transactions (append-only) ──────────────────────────────────────
    //
    //   /giftTransactions/{txId}
    //     senderId, receiverId, giftId, coins, creatorEarnings, platformFee,
    //     liveRoomId, createdAt
    //
    // Only the sender can create a transaction, and only for themselves.
    // No edits or deletes — permanent audit trail.

    match /giftTransactions/{txId} {
      // Sender or receiver can read their own transactions; Founder sees all
      allow read: if isSignedIn()
        && (request.auth.uid == resource.data.senderId
            || request.auth.uid == resource.data.receiverId
            || isFounder());

      // Sender creates the record and must identify themselves
      allow create: if isSignedIn()
        && request.auth.token.firebase.sign_in_provider != 'anonymous'
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.coins    is  int
        && request.resource.data.coins    > 0;

      // Immutable — no updates or deletes
      allow update, delete: if false;
    }

    // ── Coin Purchases (pending payment records) ──────────────────────────────
    //
    //   /coinPurchases/{txId}
    //     uid, displayName, coins, amount (cents), paymentMethod,
    //     status: 'pending' | 'completed' | 'failed', createdAt
    //     paypalOrderId (added by Cloud Function after createPayPalOrder)
    //
    // Client creates a pending record; Cloud Function (capturePayPalOrder)
    // updates status to completed and credits coins.
    // Owner (or Founder) reads only. All status updates are done server-side.

    match /coinPurchases/{txId} {
      allow read: if isSignedIn()
        && (request.auth.uid == resource.data.uid || isFounder());

      // Client creates a pending record for themselves
      allow create: if isSignedIn()
        && request.auth.token.firebase.sign_in_provider != 'anonymous'
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.amount is int
        && request.resource.data.amount >= 5;   // min 5 cents

      // Status updates are done by Cloud Functions (Admin SDK) only.
      // Direct client updates are blocked to prevent fake completion.
      allow update: if isFounder();
      allow delete: if false;
    }

    // ── Payout Requests ──────────────────────────────────────────────────────
    //
    //   /payoutRequests/{requestId}
    //     uid, paypalEmail, amountCoins, amountCents, amountUsd,
    //     status: 'processing' | 'sent' | 'failed' | 'completed'
    //     createdAt, sentAt
    //
    // Created and updated by Cloud Function (requestPayout).
    // Owner and Founder can read. No direct client writes.

    match /payoutRequests/{requestId} {
      // Creator reads their own requests; Founder sees all
      allow read: if isSignedIn()
        && (request.auth.uid == resource.data.uid || isFounder());

      // All writes are done by Cloud Functions (Admin SDK).
      // Clients cannot create, update, or delete payout records.
      allow write: if false;
    }

    // ── Creator Earnings ──────────────────────────────────────────────────────
    //
    //   /creatorEarnings/{uid}
    //     totalCoins, pendingCoins, withdrawnCoins, updatedAt
    //
    // Updated via runTransaction (gift sends). Creator reads own data.
    // Only increment operations allowed from client (no deflating earnings).

    match /creatorEarnings/{uid} {
      allow read: if isOwner(uid) || isFounder();

      // Earnings may only increase from client (gift transactions).
      // Decrements (withdrawals) must be done via Cloud Functions / Admin SDK.
      allow create: if isSignedIn()
        && request.resource.data.totalCoins   >= 0
        && request.resource.data.pendingCoins >= 0;

      allow update: if isSignedIn()
        && request.resource.data.totalCoins   >= resource.data.totalCoins
        && request.resource.data.pendingCoins >= 0;

      allow delete: if false;
    }

    // ── Wall Post Comments ─────────────────────────────────────────────────────
    //
    //   /wallPostComments/{wallDocId}/comments/{commentId}
    //     wallDocId, wallOwnerUid, authorUid, authorName, authorHandle,
    //     authorAvatar, text, createdAt
    //
    // Any signed-in user can read and create comments.
    // Only the comment author (or Founder) can delete.

    match /wallPostComments/{wallDocId} {
      allow read:  if isSignedIn();
      allow write: if false; // only subcollection comments are written

      match /comments/{commentId} {
        allow read:   if isSignedIn();
        allow create: if isSignedIn()
          && request.resource.data.authorUid == request.auth.uid;
        allow delete: if isSignedIn()
          && (resource.data.authorUid == request.auth.uid || isFounder());
        allow update: if false;
      }
    }

  }
}
