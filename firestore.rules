rules_version = '2';

//
// Shadow Nexus Social — Firestore Security Rules
//
// Collections used by this app:
//   /users/{uid}                                      — user profiles + online status
//   /stories/{storyId}                                — stories
//   /posts/{postId}                                   — feed posts
//   /chats/{channelId}                                — direct messages (1-to-1)
//   /conversations/{convId}                           — conversation metadata
//   /siteSettings/{doc}                               — site config (maintenance mode, feature flags)
//

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ─────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isFounder() {
      return isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'founder';
    }

    function isParticipant() {
      return isSignedIn()
        && request.auth.uid in resource.data.participants;
    }

    function isParticipantIncoming() {
      return isSignedIn()
        && request.auth.uid in request.resource.data.participants;
    }

    // ── Users ─────────────────────────────────────────────────────────────────

    match /users/{uid} {
      // Any signed-in user can read any profile (needed for DMs, notifications, online strip)
      allow read: if isSignedIn();
      // Only the account owner can write their own profile (including online/offline status)
      allow write: if isOwner(uid);
    }

    // ── Direct Messages (chats) ───────────────────────────────────────────────
    // A chat document ID is always uid1_uid2 (sorted).
    // Only the two participants can read or write their conversation.

    match /chats/{channelId} {
      allow read:   if isSignedIn() && isParticipant();
      allow create: if isSignedIn() && isParticipantIncoming();
      allow update: if isSignedIn() && isParticipant();
      allow delete: if isSignedIn() && isParticipant();
    }

    // ── Conversations metadata ────────────────────────────────────────────────

    match /conversations/{convId} {
      allow read:   if isSignedIn() && isParticipant();
      allow create: if isSignedIn() && isParticipantIncoming();
      allow update: if isSignedIn() && isParticipant();
      allow delete: if isSignedIn() && isParticipant();
    }

    // ── Stories ───────────────────────────────────────────────────────────────

    match /stories/{storyId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    // ── Posts ─────────────────────────────────────────────────────────────────

    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.authorUid == request.auth.uid;
    }

    // ── Site settings (maintenance mode, feature flags) ───────────────────────

    match /siteSettings/{docId} {
      allow read: if isSignedIn();
      allow write: if isFounder();
    }

    // ── AI Moderation Log ─────────────────────────────────────────────────────

    match /aiModerationLog/{docId} {
      allow create: if isSignedIn();
      allow read, delete: if isFounder();
      allow update: if false;
    }

    // ── Reports ───────────────────────────────────────────────────────────────

    match /reports/{docId} {
      allow create: if isSignedIn();
      allow read, update: if isFounder();
      allow delete: if isFounder();
    }

    // ── Audit Log ─────────────────────────────────────────────────────────────

    match /auditLog/{docId} {
      allow create: if isSignedIn();
      allow read: if isFounder();
      allow update, delete: if false;
    }

    // ── AI Toggle Log ─────────────────────────────────────────────────────────

    match /aiToggleLog/{docId} {
      allow create: if isFounder();
      allow read: if isFounder();
      allow update, delete: if false;
    }

    // ── Announcements ─────────────────────────────────────────────────────────

    match /announcements/{docId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isFounder();
    }

  }
}
